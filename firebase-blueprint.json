{
  "entities": {
    "Notice": {
      "title": "Notice",
      "description": "Departmental notices and announcements",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The notice message content" },
        "type": { "type": "string", "enum": ["info", "warning"], "description": "Severity of the notice" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "authorId": { "type": "string", "description": "UID of the admin who posted" }
      },
      "required": ["text", "type", "createdAt", "authorId"]
    },
    "Student": {
      "title": "Student",
      "description": "Student profile and academic records",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique CST Student ID" },
        "name": { "type": "string", "description": "Full name" },
        "score": { "type": "number", "description": "Current GPA" },
        "avatar": { "type": "string", "description": "Initials or avatar string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "score", "avatar"]
    },
    "Stats": {
      "title": "Dashboard Stats",
      "description": "Overall department statistics",
      "type": "object",
      "properties": {
        "totalStudents": { "type": "number" },
        "activeStudents": { "type": "number" },
        "alumni": { "type": "number" },
        "placementRate": { "type": "number" }
      },
      "required": ["totalStudents", "activeStudents", "alumni", "placementRate"]
    }
  },
  "firestore": {
    "/notices/{noticeId}": {
      "schema": "Notice",
      "description": "Real-time notice board collection"
    },
    "/leaderboard/{studentId}": {
      "schema": "Student",
      "description": "Top performing students for leaderboard"
    },
    "/settings/stats": {
      "schema": "Stats",
      "description": "Singleton document for global stats"
    }
  }
}
